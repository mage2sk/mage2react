---
/**
 * /compare — Luma-style product comparison page.
 *
 * Server-rendered: reads the `m2r_compare_uid` cookie and fetches the
 * compare list directly. The page is `noindex, follow` — compare lists
 * are per-device session data, not something we want search engines to
 * index, but any outbound catalog links should still carry link-equity.
 */
import Layout from "~/layouts/Base.astro";
import CompareTable from "~/components/compare/CompareTable.astro";

export const prerender = false;

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || "http://localhost:4321";
const canonical = new URL("/compare", SITE_URL).toString();

// Request `noindex, follow` (the Seo.astro component hard-codes
// `noindex, nofollow` when `noindex` is set, so emit our own semantics
// via the HTTP response header, which Google & Bing both honour).
Astro.response.headers.set("X-Robots-Tag", "noindex, follow");
---
<Layout
  title="Compare Products"
  description="Compare products side-by-side on mage2react."
  canonical={canonical}
>
  <meta name="robots" content="noindex, follow" />
  <CompareTable />
</Layout>
