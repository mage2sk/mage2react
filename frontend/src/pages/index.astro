---
import Layout from "~/layouts/Base.astro";
import ProductCard from "~/components/ProductCard.astro";
import PanthSlot from "~/components/panth/PanthSlot.astro";
import { getFeaturedProducts, getCmsBlocks } from "~/lib/queries";
import { sanitizeHtml } from "~/lib/sanitize";
import {
  organizationLd,
  websiteLd,
  itemListLd,
  graphLd,
  type ProductCardLike,
} from "~/lib/jsonld";

const [featured, cmsBlocks] = await Promise.all([
  getFeaturedProducts(8),
  // Magento's default "Home Page" CMS page uses these block identifiers; we
  // fetch a superset and render only the ones that actually return content.
  getCmsBlocks(["home-main-block", "home-gear-block", "home-content"]),
]);

const tiles = [
  { name: "Women", href: "/women.html", blurb: "Tops, bottoms, and outerwear" },
  { name: "Men", href: "/men.html", blurb: "Built for work and weekends" },
  { name: "Gear", href: "/gear.html", blurb: "Bags, watches, and fitness" },
];

const SITE_URL = import.meta.env.PUBLIC_SITE_URL || "http://localhost:4321";

const title = "mage2react — The fastest Magento storefront";
const description =
  "Shop the Luma collection on the fastest Magento storefront ever built.";

const heroImage = featured.items[0]?.small_image?.url ?? undefined;
const ogImage = heroImage ?? undefined;

// Emit a single <script type="application/ld+json"> block with an `@graph`
// root rather than three separate tags — Google prefers one cohesive graph
// so it can link Organization / WebSite / ItemList by @id.
const jsonLd = graphLd([
  organizationLd(SITE_URL),
  websiteLd(SITE_URL),
  itemListLd(
    featured.items as ProductCardLike[],
    (p) => (p.url_key ? `/${p.url_key}.html` : "/"),
    SITE_URL,
  ),
]);

// Pull out the two primary blocks we care about rendering above the fold;
// anything else is ignored (but still sanitised if shown).
const mainBlockHtml = cmsBlocks["home-main-block"]?.content
  ? sanitizeHtml(cmsBlocks["home-main-block"].content)
  : "";
const gearBlockHtml = cmsBlocks["home-gear-block"]?.content
  ? sanitizeHtml(cmsBlocks["home-gear-block"].content)
  : "";
---
<Layout
  title={title}
  description={description}
  ogImage={ogImage}
  ogType="website"
  jsonLd={jsonLd}
  heroImage={heroImage}
>
  <PanthSlot identifier="banner-slider:home-hero" />

  {mainBlockHtml && (
    <section class="prose max-w-none" set:html={mainBlockHtml} />
  )}

  <section class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-3">
    {tiles.map((tile) => (
      <a
        href={tile.href}
        class="group relative flex aspect-[4/3] flex-col justify-end overflow-hidden rounded-2xl bg-gradient-to-br from-zinc-200 to-zinc-300 p-6 transition hover:shadow-lg"
      >
        <h2 class="text-2xl font-bold text-zinc-900">{tile.name}</h2>
        <p class="text-sm text-zinc-700">{tile.blurb}</p>
        <span class="mt-2 text-sm font-medium text-zinc-900 group-hover:underline" aria-hidden="true">
          Shop now →
        </span>
      </a>
    ))}
  </section>

  {gearBlockHtml && (
    <section class="prose mt-16 max-w-none" set:html={gearBlockHtml} />
  )}

  <section class="mt-16">
    <div class="mb-6 flex items-end justify-between">
      <h2 class="text-2xl font-bold tracking-tight">Featured products</h2>
      <a href="/women.html" class="text-sm font-medium text-zinc-600 hover:text-zinc-900">
        View all →
      </a>
    </div>
    {featured.items.length === 0 ? (
      <p class="rounded-xl border border-dashed border-zinc-300 p-8 text-center text-zinc-500">
        No featured products available.
      </p>
    ) : (
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {featured.items.map((product, idx) => (
          <ProductCard product={product} eager={idx < 4} />
        ))}
      </div>
    )}
  </section>

  <PanthSlot identifier="product-slider:home-bestsellers" className="mt-16" />
  <PanthSlot identifier="product-slider:home-new" className="mt-8" />
  <PanthSlot identifier="testimonials:8" className="mt-16" />
</Layout>
