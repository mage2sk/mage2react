---
import Layout from "~/layouts/Base.astro";
import FormField from "~/components/customer/FormField.astro";
import FlashMessage from "~/components/customer/FlashMessage.astro";
import {
  createCustomer,
  createCustomerToken,
  friendlyAuthError,
} from "~/lib/queries-customer";
import {
  getCustomerToken,
  setCustomerToken,
  sanitizeReturnPath,
} from "~/lib/auth";
import { getStoreConfig } from "~/lib/queries";
import { z } from "zod";

if (getCustomerToken(Astro)) {
  return Astro.redirect("/customer/account", 303);
}

const storeConfig = await getStoreConfig();
const minPasswordLength = Math.max(
  8,
  Number.parseInt(storeConfig.minimum_password_length ?? "8", 10) || 8,
);

const CreateSchema = z
  .object({
    firstname: z.string().trim().min(1, "Please enter your first name.").max(128),
    lastname: z.string().trim().min(1, "Please enter your last name.").max(128),
    email: z.string().trim().email("Please enter a valid email address."),
    password: z
      .string()
      .min(minPasswordLength, `Password must be at least ${minPasswordLength} characters.`)
      .refine((v) => /[A-Za-z]/.test(v) && /[0-9]/.test(v), {
        message: "Password must include letters and numbers.",
      }),
    password_confirmation: z.string(),
    is_subscribed: z.string().optional(),
  })
  .refine((d) => d.password === d.password_confirmation, {
    path: ["password_confirmation"],
    message: "Passwords do not match.",
  });

let values: Record<string, string> = {
  firstname: "",
  lastname: "",
  email: "",
  is_subscribed: "",
};
let errors: Record<string, string> = {};
let globalError: string | null = null;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  values.firstname = String(form.get("firstname") ?? "").trim();
  values.lastname = String(form.get("lastname") ?? "").trim();
  values.email = String(form.get("email") ?? "").trim();
  values.is_subscribed = form.get("is_subscribed") ? "1" : "";
  const password = String(form.get("password") ?? "");
  const password_confirmation = String(form.get("password_confirmation") ?? "");

  const parsed = CreateSchema.safeParse({
    firstname: values.firstname,
    lastname: values.lastname,
    email: values.email,
    password,
    password_confirmation,
    is_subscribed: values.is_subscribed,
  });
  if (!parsed.success) {
    for (const issue of parsed.error.issues) {
      const key = issue.path[0];
      if (typeof key === "string" && !errors[key]) errors[key] = issue.message;
    }
  } else {
    try {
      await createCustomer({
        firstname: parsed.data.firstname,
        lastname: parsed.data.lastname,
        email: parsed.data.email,
        password: parsed.data.password,
        is_subscribed: parsed.data.is_subscribed === "1",
      });
      // Auto-login on successful registration.
      const token = await createCustomerToken(parsed.data.email, parsed.data.password);
      setCustomerToken(Astro, token);
      const rawReturn = Astro.url.searchParams.get("return");
      const returnPath = sanitizeReturnPath(rawReturn);
      const target =
        returnPath && returnPath !== "/customer/account"
          ? `${returnPath}${returnPath.includes("?") ? "&" : "?"}flash=account_created`
          : "/customer/account?flash=account_created";
      return Astro.redirect(target, 303);
    } catch (err) {
      console.warn("[customer-create] failed", {
        email: parsed.data.email,
        message: err instanceof Error ? err.message : String(err),
      });
      const raw = err instanceof Error ? err.message.toLowerCase() : "";
      if (raw.includes("already exists") || raw.includes("exists with the email")) {
        errors.email = "A customer with that email already exists.";
      } else {
        globalError = friendlyAuthError(err);
      }
    }
  }
}
---
<Layout title="Create New Customer Account" description="Create a new customer account" noindex>
  <div class="mx-auto max-w-2xl">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">Create New Customer Account</h1>
    <p class="mb-6 text-sm text-zinc-600">
      Already have an account?
      <a href="/customer/account/login" class="font-medium text-zinc-900 underline-offset-4 hover:underline">
        Sign in
      </a>.
    </p>

    {globalError && <FlashMessage message={globalError} variant="error" />}

    <form method="post" class="flex flex-col gap-6" novalidate>
      <section class="rounded-xl border border-zinc-200 bg-white p-6">
        <h2 class="mb-4 text-lg font-semibold">Personal Information</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <FormField
            id="create-firstname"
            name="firstname"
            label="First Name"
            value={values.firstname}
            required
            autocomplete="given-name"
            error={errors.firstname ?? null}
          />
          <FormField
            id="create-lastname"
            name="lastname"
            label="Last Name"
            value={values.lastname}
            required
            autocomplete="family-name"
            error={errors.lastname ?? null}
          />
        </div>
        <div class="mt-4 flex items-start gap-2">
          <input
            id="create-is_subscribed"
            type="checkbox"
            name="is_subscribed"
            value="1"
            checked={values.is_subscribed === "1"}
            class="mt-0.5 h-4 w-4 rounded border-zinc-300 text-zinc-900 focus:ring-zinc-400"
          />
          <label for="create-is_subscribed" class="text-sm text-zinc-700">
            Sign Up for Newsletter
          </label>
        </div>
      </section>

      <section class="rounded-xl border border-zinc-200 bg-white p-6">
        <h2 class="mb-4 text-lg font-semibold">Sign-in Information</h2>
        <div class="grid grid-cols-1 gap-4">
          <FormField
            id="create-email"
            name="email"
            label="Email"
            type="email"
            value={values.email}
            required
            autocomplete="email"
            error={errors.email ?? null}
          />
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <FormField
              id="create-password"
              name="password"
              label="Password"
              type="password"
              required
              autocomplete="new-password"
              minLength={minPasswordLength}
              helpText={`Minimum ${minPasswordLength} characters, with letters and numbers.`}
              error={errors.password ?? null}
            />
            <FormField
              id="create-password_confirmation"
              name="password_confirmation"
              label="Confirm Password"
              type="password"
              required
              autocomplete="new-password"
              minLength={minPasswordLength}
              error={errors.password_confirmation ?? null}
            />
          </div>
        </div>
      </section>

      <div class="flex items-center justify-between">
        <a href="/customer/account/login" class="text-sm font-medium text-zinc-600 hover:text-zinc-900">
          Back
        </a>
        <button
          type="submit"
          id="create-submit"
          class="inline-flex items-center justify-center rounded-full bg-zinc-900 px-6 py-2.5 text-sm font-semibold text-white hover:bg-zinc-800 disabled:cursor-not-allowed disabled:bg-zinc-400"
        >
          <span data-idle>Create an Account</span>
          <span data-busy hidden>Creating…</span>
        </button>
      </div>
    </form>
  </div>
</Layout>

<script>
  const form = document.querySelector("form");
  const btn = document.getElementById("create-submit") as HTMLButtonElement | null;
  if (form && btn) {
    form.addEventListener("submit", () => {
      btn.disabled = true;
      btn.querySelector("[data-idle]")?.setAttribute("hidden", "");
      btn.querySelector("[data-busy]")?.removeAttribute("hidden");
    });
  }
</script>
