---
import Layout from "~/layouts/Base.astro";
import FormField from "~/components/customer/FormField.astro";
import FlashMessage from "~/components/customer/FlashMessage.astro";
import { requestPasswordResetEmail } from "~/lib/queries-customer";
import { z } from "zod";

const EmailSchema = z.object({
  email: z.string().trim().email("Please enter a valid email address."),
});

let email = "";
let errors: Record<string, string> = {};

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  email = String(form.get("email") ?? "").trim();
  const parsed = EmailSchema.safeParse({ email });
  if (!parsed.success) {
    for (const issue of parsed.error.issues) {
      const key = issue.path[0];
      if (typeof key === "string" && !errors[key]) errors[key] = issue.message;
    }
  } else {
    // We intentionally ignore the result — never leak whether the email
    // is on file. Always render the same success message.
    await requestPasswordResetEmail(parsed.data.email);
    return Astro.redirect("/customer/account/forgotpassword?flash=reset_email_sent", 303);
  }
}
---
<Layout title="Forgot Your Password?" description="Reset your password" noindex>
  <div class="mx-auto w-full max-w-2xl">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">Forgot Your Password?</h1>
    <p class="mb-6 text-sm text-zinc-600">
      Please enter your email address below to receive a password reset link.
    </p>

    <FlashMessage />

    <form method="post" class="flex flex-col gap-4 rounded-xl border border-zinc-200 bg-white p-6" novalidate>
      <FormField
        id="forgot-email"
        name="email"
        label="Email"
        type="email"
        value={email}
        required
        autocomplete="email"
        error={errors.email ?? null}
      />
      <div class="flex items-center justify-between">
        <a href="/customer/account/login" class="text-sm font-medium text-zinc-600 hover:text-zinc-900">
          Back to Sign In
        </a>
        <button
          type="submit"
          class="inline-flex items-center rounded-full bg-zinc-900 px-6 py-2.5 text-sm font-semibold text-white hover:bg-zinc-800"
        >
          Reset My Password
        </button>
      </div>
    </form>
  </div>
</Layout>
