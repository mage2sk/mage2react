---
import Layout from "~/layouts/Base.astro";
import FormField from "~/components/customer/FormField.astro";
import FlashMessage from "~/components/customer/FlashMessage.astro";
import { resetPassword, friendlyAuthError } from "~/lib/queries-customer";
import { getStoreConfig } from "~/lib/queries";
import { z } from "zod";

const emailFromQuery = Astro.url.searchParams.get("email") ?? "";
const tokenFromQuery = Astro.url.searchParams.get("token") ?? "";

const storeConfig = await getStoreConfig();
const minPasswordLength = Math.max(
  8,
  Number.parseInt(storeConfig.minimum_password_length ?? "8", 10) || 8,
);

const ResetSchema = z
  .object({
    email: z.string().trim().email(),
    token: z.string().min(1),
    password: z.string().min(minPasswordLength, `Password must be at least ${minPasswordLength} characters.`),
    password_confirmation: z.string(),
  })
  .refine((d) => d.password === d.password_confirmation, {
    path: ["password_confirmation"],
    message: "Passwords do not match.",
  });

let errors: Record<string, string> = {};
let globalError: string | null = null;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const email = String(form.get("email") ?? "").trim();
  const token = String(form.get("token") ?? "").trim();
  const password = String(form.get("password") ?? "");
  const password_confirmation = String(form.get("password_confirmation") ?? "");

  const parsed = ResetSchema.safeParse({ email, token, password, password_confirmation });
  if (!parsed.success) {
    for (const issue of parsed.error.issues) {
      const key = issue.path[0];
      if (typeof key === "string" && !errors[key]) errors[key] = issue.message;
    }
  } else {
    try {
      const ok = await resetPassword(parsed.data.email, parsed.data.token, parsed.data.password);
      if (ok) {
        return Astro.redirect("/customer/account/login?flash=password_reset", 303);
      }
      globalError = "We could not reset your password. The link may have expired.";
    } catch (err) {
      console.warn("[customer-reset] failed", {
        message: err instanceof Error ? err.message : String(err),
      });
      globalError = friendlyAuthError(err);
    }
  }
}
---
<Layout title="Create New Password" description="Create a new password" noindex>
  <div class="mx-auto w-full max-w-2xl">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">Create New Password</h1>
    <p class="mb-6 text-sm text-zinc-600">
      Enter your new password below.
    </p>

    {globalError && <FlashMessage message={globalError} variant="error" />}

    <form method="post" class="flex flex-col gap-4 rounded-xl border border-zinc-200 bg-white p-6" novalidate>
      <input type="hidden" name="email" value={emailFromQuery} />
      <input type="hidden" name="token" value={tokenFromQuery} />
      {!emailFromQuery || !tokenFromQuery ? (
        <FlashMessage
          message="This reset link is invalid or incomplete. Please request a new link."
          variant="error"
        />
      ) : null}
      <FormField
        id="reset-email-display"
        name="email_display"
        label="Email"
        type="email"
        value={emailFromQuery}
        readonly
        autocomplete="email"
      />
      <FormField
        id="reset-password"
        name="password"
        label="New Password"
        type="password"
        required
        autocomplete="new-password"
        minLength={minPasswordLength}
        helpText={`Minimum ${minPasswordLength} characters, with letters and numbers.`}
        error={errors.password ?? null}
      />
      <FormField
        id="reset-password-confirm"
        name="password_confirmation"
        label="Confirm New Password"
        type="password"
        required
        autocomplete="new-password"
        minLength={minPasswordLength}
        error={errors.password_confirmation ?? null}
      />
      <div class="flex items-center justify-between pt-2">
        <a href="/customer/account/login" class="text-sm font-medium text-zinc-600 hover:text-zinc-900">
          Back to Sign In
        </a>
        <button
          type="submit"
          class="inline-flex items-center rounded-full bg-zinc-900 px-6 py-2.5 text-sm font-semibold text-white hover:bg-zinc-800"
        >
          Set a New Password
        </button>
      </div>
    </form>
  </div>
</Layout>
