---
import AccountLayout from "~/components/customer/AccountLayout.astro";
import AddressForm from "~/components/customer/AddressForm.astro";
import {
  getCustomer,
  getCountries,
  updateCustomerAddress,
  friendlyAuthError,
} from "~/lib/queries-customer";
import { clearCustomerToken, requireAuth } from "~/lib/auth";
import { parseAddressForm } from "~/lib/address-form";

const auth = requireAuth(Astro);
if (auth instanceof Response) return auth;
const token = auth;

const { id: idParam } = Astro.params;
const id = Number.parseInt(String(idParam ?? ""), 10);
if (!Number.isInteger(id) || id <= 0) {
  return Astro.redirect("/customer/address", 303);
}

const [countries, customer] = await Promise.all([
  getCountries(),
  getCustomer(token).catch((err) => {
    console.warn("[customer-address-edit] load failed", {
      message: err instanceof Error ? err.message : String(err),
    });
    return null;
  }),
]);

if (!customer) {
  clearCustomerToken(Astro);
  return Astro.redirect("/customer/account/login?flash=session_expired", 303);
}

const address = (customer.addresses ?? []).find((a) => a.id === id);
if (!address) {
  return Astro.redirect("/customer/address?flash=address_deleted", 303);
}

let values: Record<string, string> = {};
let errors: Record<string, string> = {};
let globalError: string | null = null;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const result = parseAddressForm(form);
  if (!result.ok) {
    values = result.values;
    errors = result.errors;
  } else {
    try {
      await updateCustomerAddress(token, id, result.input);
      return Astro.redirect("/customer/address?flash=address_updated", 303);
    } catch (err) {
      console.warn("[customer-address-edit] update failed", {
        id,
        message: err instanceof Error ? err.message : String(err),
      });
      globalError = friendlyAuthError(err);
    }
  }
}
---
<AccountLayout
  title="Edit Address"
  pageHeading="Edit Address"
  flashMessage={globalError}
  flashVariant="error"
>
  <AddressForm
    mode="edit"
    countries={countries}
    address={address}
    values={values}
    errors={errors}
  />
</AccountLayout>
