---
import Layout from "~/layouts/Base.astro";
import StepIndicator from "~/components/checkout/StepIndicator.astro";

/**
 * /checkout/success — thank-you page after placeOrder has returned. We
 * hydrate the order-number + email from short-lived HttpOnly cookies set
 * by the payment page. If either cookie is missing, the user probably
 * hit this URL by accident — bounce them to home.
 *
 * Cookies are consumed (cleared) on read so that refreshing the page
 * after 15 minutes won't show somebody else's order number on a shared
 * device.
 */
export const prerender = false;

const orderNumber = Astro.cookies.get("m2r_last_order")?.value ?? null;
const email = Astro.cookies.get("m2r_last_order_email")?.value ?? null;

if (!orderNumber) {
  return Astro.redirect("/", 303);
}

// Consume the cookies — they were one-shot anyway, and clearing them
// now prevents a back-button revisit from re-showing the page after a
// successful purchase.
Astro.cookies.delete("m2r_last_order", { path: "/" });
Astro.cookies.delete("m2r_last_order_email", { path: "/" });
---

<Layout title="Order Complete" description="Thank you for your order." noindex>
  <StepIndicator step="complete" />

  <div class="mx-auto max-w-2xl rounded-xl border border-zinc-200 bg-white p-10 text-center">
    <div class="mx-auto mb-4 inline-flex h-16 w-16 items-center justify-center rounded-full bg-emerald-50 text-emerald-600">
      <i class="bi bi-check2-circle text-4xl" aria-hidden="true"></i>
    </div>

    <h1 class="text-3xl font-bold tracking-tight text-zinc-900">
      Thank you for your purchase!
    </h1>
    <p class="mt-2 text-zinc-600">
      Your order has been placed and is being processed.
    </p>

    <dl class="mt-8 flex flex-col items-center gap-2">
      <dt class="text-sm uppercase tracking-wider text-zinc-500">Order number</dt>
      <dd class="text-3xl font-bold text-[var(--color-brand)]">#{orderNumber}</dd>
    </dl>

    {email && (
      <p class="mt-6 text-sm text-zinc-600">
        A confirmation email has been sent to <span class="font-medium text-zinc-900">{email}</span>.
      </p>
    )}

    <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
      <a
        href="/"
        class="inline-flex items-center justify-center rounded-full bg-[var(--color-brand)] px-6 py-3 text-sm font-semibold text-white hover:bg-[var(--color-brand-dark)]"
      >
        Continue Shopping
        <i class="bi bi-arrow-right ml-2" aria-hidden="true"></i>
      </a>
      <a
        href="/sales/order/history"
        class="inline-flex items-center justify-center rounded-full border border-zinc-300 px-6 py-3 text-sm font-medium text-zinc-700 hover:bg-zinc-50"
      >
        View Orders
      </a>
    </div>
  </div>
</Layout>
