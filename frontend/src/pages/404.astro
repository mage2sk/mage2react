---
import Layout from "~/layouts/Base.astro";
---
<Layout title="Not found" description="The page you're looking for doesn't exist.">
  <div class="flex flex-col items-center justify-center rounded-2xl border border-dashed border-zinc-300 px-6 py-24 text-center">
    <p class="text-sm font-semibold uppercase tracking-widest text-zinc-500">404</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">Page not found</h1>
    <p class="mt-4 max-w-md text-zinc-600">
      The page you're looking for may have been moved, removed, or never existed.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center rounded-full bg-zinc-900 px-6 py-3 text-sm font-medium text-white hover:bg-zinc-800"
    >
      Back to home
    </a>
  </div>
</Layout>
