---
import Layout from "~/layouts/Base.astro";
import SideNav from "./SideNav.astro";
import FlashMessage from "./FlashMessage.astro";

type Props = {
  title: string;
  pageHeading?: string;
  description?: string;
  showSideNav?: boolean;
  flashMessage?: string | null;
  flashVariant?: "success" | "error" | "info" | "warning";
};

const {
  title,
  pageHeading,
  description,
  showSideNav = true,
  flashMessage = null,
  flashVariant = "info",
} = Astro.props as Props;

const heading = pageHeading ?? title;
---
<Layout title={title} description={description} noindex>
  <div class="flex flex-col gap-6">
    <div class="flex flex-col gap-1">
      <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">{heading}</h1>
      {description && <p class="text-sm text-zinc-600">{description}</p>}
    </div>

    <FlashMessage message={flashMessage} variant={flashVariant} />

    <div class={showSideNav ? "grid grid-cols-1 gap-6 md:grid-cols-[240px_1fr]" : ""}>
      {showSideNav && (
        <aside class="md:block">
          <SideNav />
        </aside>
      )}
      <div class="min-w-0">
        <slot />
      </div>
    </div>
  </div>
</Layout>
