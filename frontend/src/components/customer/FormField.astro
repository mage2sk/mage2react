---
/**
 * Labelled form input with built-in error slot. Always emits
 * `aria-invalid`, `aria-describedby`, and `aria-required` so AT users
 * get parity with sighted users.
 */
type Props = {
  id: string;
  name: string;
  label: string;
  type?:
    | "text"
    | "email"
    | "password"
    | "tel"
    | "url"
    | "search"
    | "number"
    | "date";
  value?: string | number | null;
  placeholder?: string;
  required?: boolean;
  autocomplete?: string;
  minLength?: number;
  maxLength?: number;
  pattern?: string;
  error?: string | null;
  helpText?: string;
  readonly?: boolean;
  inputmode?: "none" | "text" | "decimal" | "numeric" | "tel" | "search" | "email" | "url";
};

const {
  id,
  name,
  label,
  type = "text",
  value,
  placeholder,
  required = false,
  autocomplete,
  minLength,
  maxLength,
  pattern,
  error,
  helpText,
  readonly = false,
  inputmode,
} = Astro.props as Props;

const describedBy = [
  error ? `${id}-error` : null,
  helpText ? `${id}-help` : null,
].filter(Boolean).join(" ") || undefined;

const inputClass = [
  "block w-full rounded-md border px-3 py-2 text-sm shadow-sm outline-none transition",
  error
    ? "border-red-500 focus:border-red-600 focus:ring-2 focus:ring-red-200"
    : "border-zinc-300 focus:border-zinc-900 focus:ring-2 focus:ring-zinc-200",
  readonly ? "bg-zinc-100" : "bg-white",
].join(" ");
---
<div class="flex flex-col gap-1">
  <label for={id} class="text-sm font-medium text-zinc-800">
    {label}
    {required && <span class="ml-0.5 text-red-600" aria-hidden="true">*</span>}
  </label>
  <input
    id={id}
    name={name}
    type={type}
    value={value ?? ""}
    placeholder={placeholder}
    required={required}
    autocomplete={autocomplete}
    minlength={minLength}
    maxlength={maxLength}
    pattern={pattern}
    readonly={readonly}
    inputmode={inputmode}
    aria-required={required ? "true" : undefined}
    aria-invalid={error ? "true" : undefined}
    aria-describedby={describedBy}
    class={inputClass}
  />
  {helpText && !error && (
    <p id={`${id}-help`} class="text-xs text-zinc-500">{helpText}</p>
  )}
  {error && (
    <p id={`${id}-error`} class="text-xs font-medium text-red-600" role="alert">{error}</p>
  )}
</div>
