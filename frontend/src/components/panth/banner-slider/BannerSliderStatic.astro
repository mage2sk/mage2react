---
/**
 * <BannerSliderStatic /> — SSR + client island for `Panth_BannerSlider`.
 *
 * Fetches slides on the server, pipes every admin-provided string through
 * `sanitizeHtml()`, and mounts the `<BannerCarousel client:visible />`
 * React island with the sanitized props. Renders nothing when there are
 * zero active slides.
 */
import { getBannerSlider } from "~/lib/queries-banner-slider";
import { sanitizeHtml } from "~/lib/sanitize";
import BannerCarousel from "./BannerCarousel.tsx";

interface Props {
  identifier?: string;
  heading?: string;
  autoplayMs?: number;
}

const { identifier = "home-hero", heading, autoplayMs = 6000 } = Astro.props;

const { items } = await getBannerSlider(identifier);

function cleanPlain(v: string | null | undefined): string {
  if (!v) return "";
  return sanitizeHtml(v).replace(/<[^>]*>/g, "").trim();
}

function isSafeHref(v: string | null | undefined): string | null {
  if (!v) return null;
  const s = v.trim();
  if (!s.length) return null;
  if (s.startsWith("/") || s.startsWith("#")) return s;
  if (/^https?:\/\//i.test(s)) return s;
  return null;
}

const slides = items.map((s, idx) => ({
  id: idx + 1,
  title: cleanPlain(s.title),
  subtitle: cleanPlain(s.subtitle),
  image: typeof s.image === "string" && s.image.trim().length ? s.image : null,
  alt: cleanPlain(s.alt) || cleanPlain(s.title) || `Slide ${idx + 1}`,
  cta_label: cleanPlain(s.cta_label) || null,
  cta_url: isSafeHref(s.cta_url),
}));
---
{slides.length > 0 && (
  <BannerCarousel client:visible slides={slides} autoplayMs={autoplayMs} heading={heading} />
)}
