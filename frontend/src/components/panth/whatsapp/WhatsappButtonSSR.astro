---
/**
 * <WhatsappButtonSSR /> — zero-JS floating WhatsApp chat button.
 *
 * Reads `Panth_Whatsapp` config from `core_config_data` at SSR time so the
 * button is visible on first paint, survives no-JS clients, and never needs
 * to hit the GraphQL API. Renders nothing when disabled or the phone is
 * missing/invalid.
 */
import {
  getWhatsappConfig,
  validateWhatsappColor,
} from "~/lib/queries-whatsapp";

const cfg = await getWhatsappConfig();

function positionClasses(p: string): string {
  switch (p) {
    case "bottom-left":
      return "bottom-5 left-5";
    case "top-right":
      return "top-5 right-5";
    case "top-left":
      return "top-5 left-5";
    case "bottom-right":
    default:
      return "bottom-5 right-5";
  }
}

const active = cfg.enabled && cfg.phone;
const msg = cfg.message_template ?? "";
const href = active
  ? `https://wa.me/${cfg.phone}${msg ? `?text=${encodeURIComponent(msg)}` : ""}`
  : null;
const color = validateWhatsappColor(cfg.button_color) ?? "#25D366";
const posClass = positionClasses(cfg.position);
---
{href && (
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Chat with us on WhatsApp"
    class:list={[
      "fixed z-40 inline-flex h-14 w-14 items-center justify-center rounded-full text-white shadow-lg transition-transform hover:scale-105 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2",
      posClass,
    ]}
    style={`background-color:${color}`}
  >
    <svg viewBox="0 0 32 32" width="28" height="28" fill="currentColor" aria-hidden="true">
      <path d="M16.003 2.667c-7.36 0-13.336 5.976-13.336 13.336 0 2.352.613 4.648 1.784 6.672L2.667 29.333l6.832-1.776a13.29 13.29 0 0 0 6.504 1.688h.005c7.355 0 13.331-5.976 13.331-13.331 0-3.555-1.384-6.901-3.896-9.416a13.238 13.238 0 0 0-9.44-3.831zm0 24.357h-.005a11.072 11.072 0 0 1-5.64-1.544l-.405-.24-4.056 1.064 1.08-3.952-.264-.408a11.058 11.058 0 0 1-1.693-5.907c0-6.115 4.973-11.088 11.088-11.088 2.96 0 5.744 1.155 7.832 3.248a11.007 11.007 0 0 1 3.24 7.843c-.003 6.117-4.975 11.085-11.178 11.085zm6.083-8.307c-.333-.168-1.971-.973-2.277-1.083-.304-.112-.528-.168-.752.168s-.864 1.083-1.059 1.307-.387.251-.72.083c-.333-.168-1.408-.52-2.683-1.656-.992-.885-1.661-1.979-1.856-2.315-.195-.336-.021-.517.147-.685.151-.149.336-.389.504-.584s.225-.336.336-.56c.112-.224.056-.421-.028-.589s-.752-1.811-1.029-2.48c-.272-.651-.547-.563-.752-.573l-.64-.011a1.226 1.226 0 0 0-.888.419c-.304.336-1.16 1.133-1.16 2.764s1.189 3.208 1.355 3.432c.167.224 2.341 3.573 5.672 5.011.792.341 1.411.547 1.893.699.795.253 1.52.217 2.093.132.64-.096 1.971-.805 2.248-1.581.277-.779.277-1.448.195-1.581-.084-.137-.307-.221-.64-.389z" />
    </svg>
  </a>
)}
