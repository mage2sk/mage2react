---
/**
 * <TestimonialsSlider /> — SSR + client island.
 *
 * Fetches testimonials on the server, sanitizes, and hands them to the
 * `<TestimonialsCarousel client:visible />` React island for a real
 * autoplaying carousel with arrows, dots, and per-viewport slides.
 */
import { getTestimonials } from "~/lib/queries-testimonials";
import { sanitizeHtml } from "~/lib/sanitize";
import TestimonialsCarousel from "./TestimonialsCarousel.tsx";

interface Props {
  pageSize?: number;
  heading?: string;
}

const { pageSize = 8, heading } = Astro.props;

const { items } = await getTestimonials(pageSize, 1);

function cleanPlain(v: string | null | undefined): string {
  if (!v) return "";
  return sanitizeHtml(v).replace(/<[^>]*>/g, "").trim();
}

function clampRating(v: number | null | undefined): number {
  if (typeof v !== "number" || !Number.isFinite(v)) return 0;
  return Math.max(0, Math.min(5, Math.round(v)));
}

const carouselItems = items.map((t, idx) => ({
  id: idx + 1,
  name: cleanPlain(t.customer_name) || "Anonymous",
  title: [cleanPlain(t.customer_title), cleanPlain(t.customer_company)].filter(Boolean).join(", "),
  rating: clampRating(t.rating),
  body: cleanPlain(t.body) || cleanPlain(t.title),
  photo: typeof t.photo === "string" && t.photo.trim().length ? t.photo : null,
}));
---
{carouselItems.length > 0 && (
  <TestimonialsCarousel client:visible items={carouselItems} heading={heading} />
)}
