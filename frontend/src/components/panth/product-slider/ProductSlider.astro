---
/**
 * <ProductSlider /> — SSR wrapper around the React `ProductCarousel` island.
 *
 * Reads slider config from `panth_product_slider` (via queries-product-slider)
 * and resolves product data through Magento GraphQL. Renders nothing when
 * the slug isn't configured or every SKU fails to resolve.
 */
import { getProductSlider, type ProductCardLike } from "~/lib/queries-product-slider";
import { formatMoney } from "~/lib/money";
import { sanitizeHtml } from "~/lib/sanitize";
import ProductCarousel from "./ProductCarousel.tsx";

interface Props {
  slug: string;
  heading?: string;
  subheading?: string;
}

const { slug, heading, subheading } = Astro.props;

const slider = await getProductSlider(slug);

function clean(v: string | null | undefined): string {
  if (!v) return "";
  return sanitizeHtml(v).replace(/<[^>]*>/g, "").trim();
}

function hrefFor(p: ProductCardLike): string {
  if (!p.url_key) return "#";
  return `/${p.url_key}${p.url_suffix ?? ".html"}`;
}

const products = (slider?.items ?? []).map((p) => {
  const fp = p.price_range?.minimum_price?.final_price;
  const rp = p.price_range?.minimum_price?.regular_price;
  const onSale = fp?.value != null && rp?.value != null && fp.value < rp.value;
  return {
    uid: p.uid ?? p.sku ?? p.url_key ?? Math.random().toString(36).slice(2),
    name: clean(p.name) || "Product",
    href: hrefFor(p),
    image: p.small_image?.url ?? null,
    imageAlt: clean(p.small_image?.label) || clean(p.name) || "Product",
    finalPrice: formatMoney(fp?.value ?? null, fp?.currency ?? null),
    regularPrice: rp?.value != null ? formatMoney(rp.value, rp.currency ?? null) : null,
    onSale,
  };
});

const title = clean(heading ?? slider?.title ?? "");
const subtitle = clean(subheading ?? slider?.subtitle ?? "");
---
{slider && products.length > 0 && (
  <ProductCarousel
    client:visible
    products={products}
    heading={title}
    subheading={subtitle}
    autoplay={slider.autoplay}
    autoplayMs={slider.autoplayMs}
    columnsDesktop={slider.columnsDesktop}
  />
)}
