---
// PDP integration (inside src/pages/[...slug].astro PRODUCT branch):
//   import ShareButtons from "~/components/product/ShareButtons.astro";
//   <ShareButtons title={productView.p.name} url={productView.canonical} image={productView.ogImage} />
//
// Renders a row of social share anchors + a "Copy link" button. Each social
// network is a plain `<a target="_blank" rel="noopener noreferrer">` so the
// component ships zero bytes of JavaScript for the share links. Only the
// CopyLinkButton island hydrates (client:visible) — the one interaction that
// genuinely needs script access (clipboard).
//
// All URLs are built with `encodeURIComponent` on every user-controlled value
// so product names with `&`, `?`, or `#` cannot break out of the query string.
import CopyLinkButton from "~/components/product/CopyLinkButton.tsx";

export interface Props {
  title: string;
  url: string;
  image?: string;
}

const { title, url, image } = Astro.props;

const e = encodeURIComponent;

const facebookHref = `https://www.facebook.com/sharer/sharer.php?u=${e(url)}`;
const twitterHref = `https://twitter.com/intent/tweet?url=${e(url)}&text=${e(title)}`;
const pinterestHref = image
  ? `https://pinterest.com/pin/create/button/?url=${e(url)}&description=${e(title)}&media=${e(image)}`
  : `https://pinterest.com/pin/create/button/?url=${e(url)}&description=${e(title)}`;
const whatsappHref = `https://wa.me/?text=${e(`${title} ${url}`)}`;
const mailtoHref = `mailto:?subject=${e(title)}&body=${e(url)}`;

const linkClass =
  "inline-flex h-9 w-9 items-center justify-center rounded-full border border-zinc-200 bg-white text-zinc-700 transition hover:border-[var(--color-brand)] hover:text-[var(--color-brand)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-brand)]";
---
<div class="flex flex-wrap items-center gap-2" aria-label="Share this product">
  <span class="mr-1 text-sm font-medium text-zinc-600">Share</span>

  <a
    href={facebookHref}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Share on Facebook"
    title="Share on Facebook"
    class={linkClass}
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
      <path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.88 3.77-3.88 1.1 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12Z" />
    </svg>
  </a>

  <a
    href={twitterHref}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Share on X (Twitter)"
    title="Share on X (Twitter)"
    class={linkClass}
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
      <path d="M18.244 2H21.5l-7.54 8.62L22.5 22h-6.84l-5.36-6.84L4.08 22H.82l8.06-9.22L1.5 2h6.99l4.84 6.24L18.244 2Zm-2.4 18h1.87L7.27 4H5.3l10.544 16Z" />
    </svg>
  </a>

  <a
    href={pinterestHref}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Pin on Pinterest"
    title="Pin on Pinterest"
    class={linkClass}
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
      <path d="M12 2C6.48 2 2 6.48 2 12c0 4.08 2.45 7.58 5.94 9.1-.08-.77-.15-1.97.03-2.82.17-.78 1.1-4.95 1.1-4.95s-.28-.56-.28-1.4c0-1.3.76-2.28 1.7-2.28.8 0 1.19.6 1.19 1.33 0 .81-.52 2.02-.79 3.15-.22.94.47 1.7 1.4 1.7 1.69 0 2.98-1.78 2.98-4.34 0-2.27-1.63-3.86-3.97-3.86-2.7 0-4.29 2.03-4.29 4.13 0 .82.32 1.7.71 2.17.08.1.09.18.07.28-.07.3-.24.94-.27 1.07-.04.17-.14.21-.32.13-1.2-.56-1.95-2.3-1.95-3.71 0-3.02 2.19-5.79 6.32-5.79 3.32 0 5.9 2.37 5.9 5.53 0 3.3-2.08 5.95-4.97 5.95-.97 0-1.88-.5-2.19-1.1l-.6 2.27c-.21.82-.79 1.86-1.18 2.49A10 10 0 0 0 22 12c0-5.52-4.48-10-10-10Z" />
    </svg>
  </a>

  <a
    href={whatsappHref}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Share on WhatsApp"
    title="Share on WhatsApp"
    class={linkClass}
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
      <path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.95 1.17-.17.2-.35.22-.65.07-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.47-1.75-1.64-2.05-.17-.3-.02-.46.13-.6.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.38-.03-.53-.08-.15-.67-1.6-.92-2.2-.24-.58-.49-.5-.67-.5h-.57c-.2 0-.52.07-.8.38-.27.3-1.04 1.02-1.04 2.5 0 1.47 1.07 2.9 1.22 3.1.15.2 2.1 3.2 5.1 4.48.71.3 1.27.48 1.7.62.71.22 1.37.19 1.88.12.57-.09 1.76-.72 2.01-1.42.25-.7.25-1.3.17-1.42-.07-.13-.27-.2-.57-.35Z M12 2a10 10 0 0 0-8.48 15.3L2 22l4.8-1.52A10 10 0 1 0 12 2Zm0 18.1a8.1 8.1 0 0 1-4.13-1.14l-.3-.17-2.85.9.93-2.77-.19-.3A8.1 8.1 0 1 1 12 20.1Z" />
    </svg>
  </a>

  <a
    href={mailtoHref}
    aria-label="Share via email"
    title="Share via email"
    class={linkClass}
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4" aria-hidden="true">
      <rect x="3" y="5" width="18" height="14" rx="2" />
      <path d="m3 7 9 6 9-6" />
    </svg>
  </a>

  <CopyLinkButton client:visible url={url} />
</div>
