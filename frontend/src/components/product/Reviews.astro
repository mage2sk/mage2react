---
// PDP integration (inside src/pages/[...slug].astro PRODUCT branch, below description):
//   ---
//   import Reviews from "~/components/product/Reviews.astro";
//   import ReviewForm from "~/components/product/ReviewForm.tsx";
//   import { getReviewMetadata } from "~/lib/queries-reviews";
//   const metadata = await getReviewMetadata();
//   ---
//   <Reviews sku={productView.p.sku} />
//   <ReviewForm client:visible sku={productView.p.sku} metadata={metadata} />

/**
 * Reviews — server-rendered product reviews list with pagination.
 *
 * Data comes from `getProductReviews(sku, page, pageSize)`. The `?rp=N` query
 * parameter controls the page (falls back to 1). We render:
 *   - Header with the aggregate rating (`rating_summary` / `review_count`).
 *   - One card per review: stars, nickname, formatted date, bold summary,
 *     sanitized text body, per-rating breakdown.
 *   - Prev/Next pagination links that preserve existing query params.
 *   - Empty state inviting the customer to leave the first review.
 *
 * All HTML from Magento passes through `sanitizeHtml` before rendering.
 */
import { getProductReviews } from "~/lib/queries-reviews";
import { sanitizeHtml } from "~/lib/sanitize";
import RatingStars from "./RatingStars.astro";

export interface Props {
  sku: string;
  pageSize?: number;
}

const { sku, pageSize = 10 } = Astro.props;

const rpRaw = Astro.url.searchParams.get("rp");
const rpParsed = rpRaw ? Number.parseInt(rpRaw, 10) : 1;
const currentPage = Number.isFinite(rpParsed) && rpParsed > 0 ? rpParsed : 1;

let result: Awaited<ReturnType<typeof getProductReviews>>;
try {
  result = await getProductReviews(sku, currentPage, pageSize);
} catch {
  result = {
    items: [],
    totalPages: 0,
    currentPage,
    pageSize,
    reviewCount: 0,
    ratingSummary: 0,
  };
}

function formatDate(iso: string | null): string {
  if (!iso) return "";
  // Magento returns `YYYY-MM-DD HH:mm:ss` (server tz) — Date can parse it.
  const d = new Date(iso.replace(" ", "T"));
  if (Number.isNaN(d.getTime())) return iso;
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

function buildPageUrl(p: number): string {
  const url = new URL(Astro.url.href);
  url.searchParams.set("rp", String(p));
  // Preserve hash so the browser jumps back to this section after navigation.
  return `${url.pathname}${url.search}#reviews`;
}

const summaryOutOf5 = (result.ratingSummary / 20).toFixed(1);
const prevPage = currentPage > 1 ? currentPage - 1 : null;
const nextPage = currentPage < result.totalPages ? currentPage + 1 : null;
---

<section id="reviews" class="mt-12 border-t border-zinc-200 pt-8">
  <header class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
    <h2 class="text-2xl font-bold text-zinc-900">Customer reviews</h2>
    {result.reviewCount > 0 && (
      <div class="flex items-center gap-3">
        <RatingStars value={result.ratingSummary} scale={100} size="md" label={`Average rating ${summaryOutOf5} of 5`} />
        <span class="text-sm text-zinc-700">
          <strong>{summaryOutOf5} / 5</strong>
          <span class="text-zinc-500"> — {result.reviewCount} {result.reviewCount === 1 ? "review" : "reviews"}</span>
        </span>
      </div>
    )}
  </header>

  {result.items.length === 0 && (
    <p class="mt-6 rounded-lg bg-zinc-50 px-4 py-6 text-center text-zinc-600">
      Be the first to review this product.
    </p>
  )}

  {result.items.length > 0 && (
    <ul class="mt-6 space-y-6">
      {result.items.map((r) => (
        <li class="rounded-lg border border-zinc-200 bg-white p-4 sm:p-5">
          <div class="flex flex-wrap items-center gap-3">
            <RatingStars
              value={r.average_rating ?? 0}
              scale={100}
              size="sm"
              label={`Rated ${((r.average_rating ?? 0) / 20).toFixed(1)} of 5`}
            />
            <span class="text-sm font-medium text-zinc-900">{r.nickname ?? "Anonymous"}</span>
            {r.created_at && (
              <span class="text-xs text-zinc-500">{formatDate(r.created_at)}</span>
            )}
          </div>

          {r.summary && (
            <p class="mt-2 font-semibold text-zinc-900">{r.summary}</p>
          )}

          {r.text && (
            <div
              class="mt-2 text-sm leading-relaxed text-zinc-700"
              set:html={sanitizeHtml(r.text)}
            />
          )}

          {r.ratings_breakdown && r.ratings_breakdown.length > 0 && (
            <p class="mt-3 text-xs text-zinc-500">
              {r.ratings_breakdown
                .filter((b) => b.name && b.value)
                .map((b) => `${b.name}: ${b.value}/5`)
                .join(" · ")}
            </p>
          )}
        </li>
      ))}
    </ul>
  )}

  {result.totalPages > 1 && (
    <nav class="mt-6 flex items-center justify-between" aria-label="Review pagination">
      {prevPage !== null ? (
        <a
          href={buildPageUrl(prevPage)}
          class="inline-flex items-center gap-1 rounded-full border border-zinc-300 bg-white px-4 py-2 text-sm font-medium text-zinc-700 hover:border-zinc-500"
          rel="prev"
        >
          &larr; Previous
        </a>
      ) : (
        <span aria-hidden="true"></span>
      )}
      <span class="text-sm text-zinc-500">
        Page {currentPage} of {result.totalPages}
      </span>
      {nextPage !== null ? (
        <a
          href={buildPageUrl(nextPage)}
          class="inline-flex items-center gap-1 rounded-full border border-zinc-300 bg-white px-4 py-2 text-sm font-medium text-zinc-700 hover:border-zinc-500"
          rel="next"
        >
          Next &rarr;
        </a>
      ) : (
        <span aria-hidden="true"></span>
      )}
    </nav>
  )}
</section>
