---
/**
 * Footer — Luma-style four-column footer.
 *
 * Columns:
 *   1. Company        — About Us, Customer Service, Contact Us, Careers.
 *   2. Customer Service — Help/FAQ, Shipping & Returns, T&Cs, Privacy, CCPA.
 *   3. Subscribe      — Newsletter React island (client:idle).
 *   4. Connect        — Social icon links.
 *
 * Below the grid: payment-method icons + merchant copyright. The copyright
 * HTML is sanitized by the caller (Base.astro) and passed in as a prop to
 * avoid re-fetching / re-sanitizing per render.
 */
import Newsletter from "~/components/Newsletter.tsx";

type Props = {
  copyrightHtml: string;
};

const { copyrightHtml } = Astro.props;

type LinkItem = { label: string; href: string };

// Placeholder `#` hrefs get `rel="nofollow"` when rendered (see loop below)
// so they don't leak PageRank from internal linking into nowhere.
const companyLinks: LinkItem[] = [
  { label: "About Us", href: "/about-us" },
  { label: "Customer Service", href: "/customer-service" },
  { label: "Contact Us", href: "/contact" },
  { label: "Careers", href: "#" },
];

const serviceLinks: LinkItem[] = [
  { label: "Help / FAQ", href: "/customer-service" },
  { label: "Shipping & Returns", href: "/shipping-returns" },
  { label: "Terms & Conditions", href: "/terms" },
  { label: "Privacy Policy", href: "/privacy-policy-cookie-restriction-mode" },
  { label: "CCPA", href: "/enable-cookies" },
];

type SocialItem = {
  label: string;
  href: string;
  path: string;
};

// Pure SVG path data for each social glyph. All use a 24x24 viewBox.
const socials: SocialItem[] = [
  {
    label: "Facebook",
    href: "#",
    path: "M13 22v-8h3l1-4h-4V7.5C13 6.5 13.4 6 14.6 6H17V2.2A26 26 0 0 0 14.3 2C11.6 2 10 3.7 10 6.7V10H7v4h3v8h3z",
  },
  {
    label: "Twitter",
    href: "#",
    path: "M22 5.9a8.2 8.2 0 0 1-2.4.7 4.2 4.2 0 0 0 1.8-2.3 8.3 8.3 0 0 1-2.6 1 4.1 4.1 0 0 0-7 3.7A11.6 11.6 0 0 1 3.2 4.7a4.1 4.1 0 0 0 1.3 5.5 4 4 0 0 1-1.9-.5v.1a4.1 4.1 0 0 0 3.3 4 4.1 4.1 0 0 1-1.9.1 4.1 4.1 0 0 0 3.8 2.9A8.3 8.3 0 0 1 2 18.6 11.7 11.7 0 0 0 8.3 20.5c7.5 0 11.7-6.3 11.7-11.7v-.5A8.3 8.3 0 0 0 22 5.9z",
  },
  {
    label: "Instagram",
    href: "#",
    path: "M12 2.2c3.2 0 3.6 0 4.8.1 1.2 0 1.9.3 2.3.5a3.8 3.8 0 0 1 1.4.9 3.8 3.8 0 0 1 .9 1.4c.2.4.4 1.1.5 2.3.1 1.2.1 1.6.1 4.8s0 3.6-.1 4.8c0 1.2-.3 1.9-.5 2.3a3.8 3.8 0 0 1-.9 1.4 3.8 3.8 0 0 1-1.4.9c-.4.2-1.1.4-2.3.5-1.2.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2 0-1.9-.3-2.3-.5a3.8 3.8 0 0 1-1.4-.9 3.8 3.8 0 0 1-.9-1.4c-.2-.4-.4-1.1-.5-2.3C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.8c0-1.2.3-1.9.5-2.3a3.8 3.8 0 0 1 .9-1.4 3.8 3.8 0 0 1 1.4-.9c.4-.2 1.1-.4 2.3-.5C8.4 2.2 8.8 2.2 12 2.2zm0 5.3a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9zm0 7.4a2.9 2.9 0 1 1 0-5.8 2.9 2.9 0 0 1 0 5.8zM17.8 7a1.1 1.1 0 1 0 0-2.2 1.1 1.1 0 0 0 0 2.2z",
  },
  {
    label: "Pinterest",
    href: "#",
    path: "M12.1 2a10 10 0 0 0-3.6 19.3c0-.8-.2-2 0-2.9l1.3-5.4s-.3-.7-.3-1.7c0-1.6.9-2.8 2.1-2.8 1 0 1.5.7 1.5 1.6 0 1-.6 2.5-.9 3.9-.3 1.2.6 2.1 1.7 2.1 2.1 0 3.6-2.2 3.6-5.3 0-2.8-2-4.7-4.9-4.7a5 5 0 0 0-5.2 5c0 1 .4 2 .9 2.6.1.1.1.2.1.3l-.3 1.3c0 .2-.2.3-.4.2-1.4-.7-2.3-2.7-2.3-4.4 0-3.6 2.6-6.9 7.5-6.9 3.9 0 7 2.8 7 6.5 0 3.9-2.5 7.1-5.9 7.1-1.1 0-2.2-.6-2.6-1.3l-.7 2.8c-.3 1-1 2.3-1.4 3.1A10 10 0 1 0 12.1 2z",
  },
  {
    label: "YouTube",
    href: "#",
    path: "M23 7.2s-.2-1.6-.9-2.3c-.8-.9-1.8-.9-2.2-1C16.7 3.5 12 3.5 12 3.5s-4.7 0-7.9.4c-.4.1-1.4.1-2.2 1C1.2 5.6 1 7.2 1 7.2S.7 9 .7 10.9v1.8c0 1.8.3 3.7.3 3.7s.2 1.6.9 2.3c.9 1 2 .9 2.5 1 1.8.1 7.6.4 7.6.4s4.7 0 7.9-.4c.4-.1 1.4-.1 2.2-1 .7-.7.9-2.3.9-2.3s.3-1.8.3-3.7v-1.8c0-1.9-.3-3.7-.3-3.7zM9.8 14.4V8l6.1 3.2-6.1 3.2z",
  },
];

type PaymentIcon = {
  label: string;
  /** Abbreviation rendered inside the chip; purely decorative. */
  text: string;
};

const paymentMethods: PaymentIcon[] = [
  { label: "Visa", text: "VISA" },
  { label: "Mastercard", text: "MC" },
  { label: "American Express", text: "AMEX" },
  { label: "PayPal", text: "PayPal" },
];
---
<footer class="mt-16 border-t border-zinc-200 bg-zinc-50 text-zinc-700">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Company -->
      <section aria-labelledby="footer-company">
        <h2 id="footer-company" class="mb-3 text-sm font-semibold uppercase tracking-wide text-zinc-900">
          Company
        </h2>
        <ul class="space-y-2 text-sm">
          {companyLinks.map((item) => (
            <li>
              <a
                href={item.href}
                rel={item.href === "#" ? "nofollow" : undefined}
                class="inline-block hover:text-[var(--color-brand)]"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </section>

      <!-- Customer Service -->
      <section aria-labelledby="footer-service">
        <h2 id="footer-service" class="mb-3 text-sm font-semibold uppercase tracking-wide text-zinc-900">
          Customer Service
        </h2>
        <ul class="space-y-2 text-sm">
          {serviceLinks.map((item) => (
            <li>
              <a
                href={item.href}
                rel={item.href === "#" ? "nofollow" : undefined}
                class="inline-block hover:text-[var(--color-brand)]"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </section>

      <!-- Subscribe -->
      <section aria-labelledby="footer-subscribe" class="sm:col-span-2 lg:col-span-1">
        <h2 id="footer-subscribe" class="sr-only">Subscribe</h2>
        <Newsletter client:idle />
      </section>

      <!-- Connect -->
      <section aria-labelledby="footer-connect">
        <h2 id="footer-connect" class="mb-3 text-sm font-semibold uppercase tracking-wide text-zinc-900">
          Connect
        </h2>
        <ul class="flex flex-wrap gap-3">
          {socials.map((s) => (
            <li>
              <a
                href={s.href}
                aria-label={`Follow us on ${s.label}`}
                rel={s.href === "#" ? "nofollow noopener" : "noopener"}
                class="grid size-10 place-items-center rounded-full border border-zinc-300 bg-white text-zinc-700 transition hover:border-[var(--color-brand)] hover:text-[var(--color-brand)]"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  class="size-5"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d={s.path} />
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </div>
  </div>

  <!-- Fine print: payments + copyright -->
  <div class="border-t border-zinc-200 bg-white">
    <div class="mx-auto flex max-w-6xl flex-col items-center gap-4 px-4 py-6 text-xs text-zinc-500 sm:flex-row sm:justify-between">
      <p class="order-2 text-center sm:order-1 sm:text-left" set:html={copyrightHtml} />
      <ul class="order-1 flex flex-wrap items-center gap-2 sm:order-2" aria-label="Accepted payment methods">
        {paymentMethods.map((pm) => (
          <li
            class="inline-flex items-center rounded border border-zinc-200 bg-zinc-50 px-2 py-1 text-[10px] font-semibold tracking-wide text-zinc-700"
            role="img"
            aria-label={pm.label}
            title={pm.label}
          >
            {pm.text}
          </li>
        ))}
      </ul>
    </div>
  </div>
</footer>
