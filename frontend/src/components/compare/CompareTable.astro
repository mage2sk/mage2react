---
/**
 * CompareTable — server-rendered horizontal-scrolling compare grid.
 *
 * Reads the compare list UID from `m2r_compare_uid`, fetches the list via
 * the Magento GraphQL endpoint, and renders a Luma-style comparison table
 * (products across, attributes down).
 *
 * Row 0 holds the thumbnail, name, price, and per-column remove button.
 * Each subsequent row maps to one attribute reported by the schema
 * (`list.attributes[]`). Attribute values may contain HTML (Magento
 * description fields in particular) so every cell is piped through
 * `sanitizeHtml`.
 *
 * The remove / clear-all controls are plain `<form method="post">`
 * submissions so the table works without JavaScript. The client-side
 * `compare-store` also listens on the cookie, so post-redirect the
 * in-memory atoms resync on the next page view.
 */
import {
  COMPARE_COOKIE_NAME,
  getCompareList,
  removeProductsFromCompareList,
  deleteCompareList,
  type CompareItemT,
  type CompareListT,
} from "~/lib/queries-compare";
import { sanitizeHtml } from "~/lib/sanitize";
import { formatMoney } from "~/lib/money";

// POST handler: supports `remove` (remove one product) and `clear` (delete list).
let flash: string | null = null;
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const intent = String(form.get("intent") ?? "");
  const uid = Astro.cookies.get(COMPARE_COOKIE_NAME)?.value ?? null;

  if (intent === "remove" && uid) {
    const productUid = String(form.get("product_uid") ?? "");
    if (productUid) {
      try {
        await removeProductsFromCompareList(uid, [productUid]);
      } catch (err) {
        console.warn("[compare] remove failed", {
          message: err instanceof Error ? err.message : String(err),
        });
        flash = "Couldn't remove item, try again.";
      }
    }
  } else if (intent === "clear" && uid) {
    try {
      await deleteCompareList(uid);
    } catch (err) {
      console.warn("[compare] clear failed", {
        message: err instanceof Error ? err.message : String(err),
      });
    }
    Astro.cookies.delete(COMPARE_COOKIE_NAME, { path: "/" });
    return Astro.redirect("/compare", 303);
  }
}

const uid = Astro.cookies.get(COMPARE_COOKIE_NAME)?.value ?? null;
let list: CompareListT | null = null;
let unreachable = false;
if (uid) {
  try {
    list = await getCompareList(uid);
  } catch (err) {
    console.warn("[compare] load failed", {
      message: err instanceof Error ? err.message : String(err),
    });
    unreachable = true;
  }
}

const items: CompareItemT[] = (list?.items ?? []).filter(
  (it): it is CompareItemT => it != null,
);
const attributes = list?.attributes ?? [];

// Build a quick lookup of attribute value per product for O(1) cell render.
function attrValueFor(item: CompareItemT, code: string): string | null {
  const attr = (item.attributes ?? []).find((a) => a.code === code);
  return attr?.value ?? null;
}

function productHref(item: CompareItemT): string {
  const key = item.product.url_key;
  if (!key) return "#";
  const suffix = item.product.url_suffix ?? ".html";
  return `/${key}${suffix}`;
}
---
{flash && (
  <div class="mb-4 rounded-md border border-red-200 bg-red-50 px-4 py-2 text-sm text-red-700" role="alert">
    {flash}
  </div>
)}

{unreachable ? (
  <section class="py-16 text-center">
    <h1 class="text-2xl font-bold text-zinc-900">Compare is temporarily unavailable</h1>
    <p class="mt-2 text-sm text-zinc-500">Please try again in a moment.</p>
    <a href="/" class="mt-6 inline-block text-sm font-medium text-[var(--color-brand)] hover:underline">
      Return to home
    </a>
  </section>
) : items.length === 0 ? (
  <section class="py-16 text-center">
    <h1 class="text-2xl font-bold text-zinc-900">Compare Products</h1>
    <p class="mt-4 rounded-xl border border-dashed border-zinc-300 p-8 text-sm text-zinc-500">
      You have no items to compare.
    </p>
    <a href="/" class="mt-6 inline-block text-sm font-medium text-[var(--color-brand)] hover:underline">
      Continue shopping
    </a>
  </section>
) : (
  <section>
    <div class="mb-4 flex items-center justify-between gap-4">
      <h1 class="text-2xl font-bold text-zinc-900">
        Compare Products
        <span class="ml-2 text-sm font-normal text-zinc-500">
          ({items.length} {items.length === 1 ? "item" : "items"})
        </span>
      </h1>
      <form method="post" data-confirm="Clear the compare list?">
        <input type="hidden" name="intent" value="clear" />
        <button
          type="submit"
          class="inline-flex items-center gap-1.5 rounded-full border border-zinc-300 bg-white px-3 py-1.5 text-xs font-medium text-zinc-700 hover:border-red-500 hover:text-red-600"
        >
          Clear All
        </button>
      </form>
    </div>

    <div class="overflow-x-auto rounded-xl border border-zinc-200 bg-white">
      <table class="w-full min-w-max border-separate border-spacing-0 text-sm">
        <thead>
          <tr>
            <th scope="col" class="sticky left-0 z-10 border-b border-r border-zinc-200 bg-zinc-50 p-3 text-left text-xs font-semibold uppercase tracking-wide text-zinc-500" style="min-width: 140px">
              Product
            </th>
            {items.map((item) => {
              const img = item.product.small_image;
              const final = item.product.price_range.minimum_price.final_price;
              const href = productHref(item);
              return (
                <th scope="col" class="border-b border-zinc-200 bg-white p-4 text-center align-top font-normal" style="min-width: 220px">
                  <form method="post" class="mb-2 flex justify-end">
                    <input type="hidden" name="intent" value="remove" />
                    <input type="hidden" name="product_uid" value={item.product.uid} />
                    <button
                      type="submit"
                      class="rounded-full p-1 text-zinc-400 hover:bg-zinc-100 hover:text-red-600"
                      aria-label={`Remove ${item.product.name} from compare`}
                      title={`Remove ${item.product.name} from compare`}
                    >
                      <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                      </svg>
                    </button>
                  </form>
                  <a href={href} class="block">
                    <div class="mx-auto flex size-[180px] items-center justify-center overflow-hidden rounded-lg bg-zinc-50">
                      {img?.url ? (
                        <img
                          src={img.url}
                          alt={img.label ?? item.product.name}
                          width={180}
                          height={180}
                          loading="lazy"
                          decoding="async"
                          class="h-full w-full object-cover"
                        />
                      ) : (
                        <span class="text-xs text-zinc-400">No image</span>
                      )}
                    </div>
                    <p class="mt-3 line-clamp-2 text-sm font-medium text-zinc-900 hover:text-[var(--color-brand)]">
                      {item.product.name}
                    </p>
                  </a>
                  <p class="mt-1 text-sm font-semibold text-zinc-900">
                    {formatMoney(final.value, final.currency)}
                  </p>
                </th>
              );
            })}
          </tr>
        </thead>
        <tbody>
          {attributes.map((attr) => (
            <tr>
              <th scope="row" class="sticky left-0 z-10 border-b border-r border-zinc-200 bg-zinc-50 p-3 text-left text-xs font-semibold uppercase tracking-wide text-zinc-600">
                {attr.label}
              </th>
              {items.map((item) => {
                const raw = attrValueFor(item, attr.code);
                return (
                  <td class="border-b border-zinc-200 p-3 align-top text-sm text-zinc-700">
                    {raw ? (
                      <div class="prose prose-sm max-w-none" set:html={sanitizeHtml(raw)} />
                    ) : (
                      <span class="text-zinc-400">—</span>
                    )}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
)}

<script>
  for (const form of document.querySelectorAll<HTMLFormElement>("form[data-confirm]")) {
    form.addEventListener("submit", (e) => {
      const msg = form.getAttribute("data-confirm") ?? "Are you sure?";
      if (!window.confirm(msg)) e.preventDefault();
    });
  }
</script>
